{
  "name": "unsweets",
  "version": "2.0.0",
  "description": "unsweets.net is a website that publishes my application by _X_y_z_.",
  "private": true,
  "devDependencies": {
    "eslint": "^3.11.1",
    "livereload": "^0.6.2",
    "nodemon": "^1.11.0",
    "pre-commit": "^1.2.2"
  },
  "scripts": {
    "test": "eslint src/js/**/*.js",
    "fix": "eslint --fix src/js/**/*.js",
    "start": "concurrently --kill-others \"http-server -c-1 build\" \"npm run watch\" \"npm run livereload\"",
    "livereload": "livereload build/",
    "watch": "concurrently --kill-others \"npm run build:html:watch\" \"npm run build:image:watch\" \"npm run build:css:watch\" \"npm run build:js:watch\"",
    "build": "concurrently \"npm run build:html\" \"npm run build:image\" \"npm run build:css\" \"npm run build:js\" && npm run build:other",
    "build:html": "html-minifier --collapse-whitespace --minify-js --minify-css --input-dir src/ --output-dir build/ --file-ext html",
    "build:html:watch": "nodemon --watch src/ -e html -q -x \"npm run build:html\"",
    "build:image": "imagemin src/images/* --out-dir=build/images && imagemin src/images/favicons/* --out-dir=build/images/favicons",
    "build:image:watch": "nodemon --watch src/images -e png,svg -q -x \"npm run build:image\"",
    "build:css": "postcss src/css/main.css -o build/css/main.css",
    "build:css:watch": "nodemon --watch src/css -e css -q -x \"npm run build:css\"",
    "build:js": "rollup -c --format=iife",
    "build:js:watch": "nodemon --watch src/js -q -x \"npm run build:js\"",
    "build:other": "cp src/humans.txt src/favicon.ico src/robots.txt build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sunya9/unsweets.net.git"
  },
  "author": "_X_y_z_",
  "bugs": {
    "url": "https://github.com/sunya9/unsweets.net/issues"
  },
  "homepage": "https://github.com/sunya9/unsweets.net",
  "dependencies": {
    "babel-plugin-external-helpers": "^6.22.0",
    "babel-preset-es2015": "^6.24.1",
    "concurrently": "^3.4.0",
    "cssnano": "^3.10.0",
    "html-minifier": "^3.4.4",
    "http-server": "^0.10.0",
    "imagemin-cli": "^3.0.0",
    "lodash.debounce": "^4.0.8",
    "normalize.css": "^7.0.0",
    "postcss": "^6.0.1",
    "postcss-cli": "3",
    "postcss-cssnext": "^2.10.0",
    "postcss-import": "8",
    "rollup": "^0.41.6",
    "rollup-plugin-babel": "^2.7.1",
    "rollup-plugin-commonjs": "^8.0.2",
    "rollup-plugin-node-resolve": "^3.0.0",
    "rollup-plugin-uglify": "^1.0.2"
  },
  "pre-commit": [
    "test"
  ]
}
