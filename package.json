{
  "name": "unsweets",
  "version": "2.0.2",
  "description": "unsweets.net is a website that publishes my application by _X_y_z_.",
  "private": true,
  "devDependencies": {
    "@babel/core": "7.9.6",
    "@babel/plugin-external-helpers": "7.8.3",
    "@babel/preset-env": "7.9.6",
    "@rollup/plugin-commonjs": "11.1.0",
    "@rollup/plugin-node-resolve": "7.1.3",
    "cssnano": "4.1.10",
    "eslint": "6.8.0",
    "html-minifier": "4.0.0",
    "husky": "4.2.5",
    "imagemin-cli": "5.1.0",
    "npm-run-all": "4.1.5",
    "postcss-cli": "7.1.1",
    "postcss-color-gray": "5.0.0",
    "postcss-import": "12.0.1",
    "postcss-preset-env": "6.7.0",
    "rollup": "2.9.0",
    "rollup-plugin-babel": "4.4.0",
    "rollup-plugin-serve": "1.0.1",
    "rollup-plugin-uglify": "6.0.4"
  },
  "scripts": {
    "test": "eslint src/js/**/*.js",
    "fix": "eslint --fix src/js/**/*.js",
    "dev": "run-p 'build:js -- --watch' 'build:css -- --watch'",
    "build": "mkdir -p build && run-p build:html build:image build:css build:js build:other",
    "build:html": "html-minifier --collapse-whitespace --minify-js --minify-css --input-dir static --output-dir build/ --file-ext html",
    "build:image": "imagemin static/images/* --out-dir=build/images && imagemin static/images/favicons/* --out-dir=build/images/favicons",
    "build:css": "postcss src/css/main.css -o build/css/main.css",
    "build:js": "rollup -c",
    "build:other": "cp static/humans.txt static/favicon.ico static/robots.txt build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sunya9/unsweets.net.git"
  },
  "author": "_X_y_z_",
  "bugs": {
    "url": "https://github.com/sunya9/unsweets.net/issues"
  },
  "homepage": "https://github.com/sunya9/unsweets.net",
  "dependencies": {
    "lodash.debounce": "4.0.8",
    "normalize.css": "8.0.1"
  },
  "pre-commit": [
    "test"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "npm test"
    }
  }
}
